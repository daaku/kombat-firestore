{
  "name": "@daaku/kombat-firestore",
  "author": "Naitik Shah <n@daaku.org>",
  "version": "2.7.0",
  "description": "Kombat storage implemented using Firebase Firestore.",
  "repository": "git@github.com:daaku/kombat-firestore",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": { "import": "./dist/src/index.js", "types": "./dist/src/index.d.ts" },
    "./test": {
      "import": "./dist/src/test.js",
      "types": "./dist/src/test.d.ts"
    }
  },
  "prettier": {
    "arrowParens": "avoid",
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "scripts": {
    "test": "vite build && TIMEOUT=30000 qunit-puppeteer",
    "prepare": "tsc",
    "dev": "vite"
  },
  "keywords": ["kombat", "crdt", "firebase", "firestore"],
  "devDependencies": {
    "@daaku/qunit-puppeteer": "^4.1.0",
    "@types/qunit": "^2.19.13",
    "nanoid": "^5.1.7",
    "qunit": "^2.25.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "@daaku/firebase-rest-api": "^2.4.0",
    "@daaku/kombat": "^2.17.0"
  }
}
